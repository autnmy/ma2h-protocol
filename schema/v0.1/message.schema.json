{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ahcpprotocol.org/schema/v0.1/message.schema.json",
  "title": "AHCP Message (v0.1)",
  "description": "Envelope for an Agent Human Coordination Protocol message. Discriminated on `type`.",
  "type": "object",
  "required": ["a2h_version", "id", "type", "created_at", "agent", "title"],
  "properties": {
    "a2h_version": { "const": "0.1" },
    "id": { "type": "string", "minLength": 1 },
    "type": { "enum": ["notify", "ask", "task"] },
    "created_at": { "type": "string", "format": "date-time" },
    "agent": { "$ref": "#/$defs/agent" },
    "title": { "type": "string", "maxLength": 200 },
    "body": { "type": "string" },
    "priority": { "enum": ["low", "normal", "high", "urgent"], "default": "normal" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "context": { "type": "array", "items": { "$ref": "#/$defs/part" } },
    "expires_at": { "type": "string", "format": "date-time" },
    "idempotency_key": { "type": "string" },
    "request": { "$ref": "#/$defs/request" },
    "action": { "$ref": "#/$defs/action" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "ask" } } },
      "then": { "required": ["request"] }
    },
    {
      "if": { "properties": { "type": { "const": "task" } } },
      "then": { "required": ["action"] }
    }
  ],
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["id", "run_id", "runtime"],
      "properties": {
        "id": { "type": "string" },
        "run_id": { "type": "string" },
        "runtime": { "enum": ["github-actions", "cli", "cloud", "desktop", "openclaw", "other"] },
        "project": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "part": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "text"],
          "properties": { "kind": { "const": "text" }, "text": { "type": "string" }, "metadata": { "type": "object" } }
        },
        {
          "type": "object",
          "required": ["kind", "data"],
          "properties": { "kind": { "const": "data" }, "data": { "type": "object" }, "metadata": { "type": "object" } }
        },
        {
          "type": "object",
          "required": ["kind", "file"],
          "properties": {
            "kind": { "const": "file" },
            "file": {
              "type": "object",
              "required": ["uri"],
              "properties": {
                "uri": { "type": "string", "format": "uri" },
                "name": { "type": "string" },
                "mime_type": { "type": "string" }
              }
            },
            "metadata": { "type": "object" }
          }
        }
      ]
    },
    "request": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["select", "input", "confirm"] },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "label"],
            "properties": {
              "value": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "schema": { "type": "object", "description": "Flat JSON Schema; string/number/boolean/enum only." },
        "permissions": {
          "type": "object",
          "properties": {
            "allow_accept": { "type": "boolean" },
            "allow_edit": { "type": "boolean" },
            "allow_respond": { "type": "boolean" },
            "allow_ignore": { "type": "boolean" }
          }
        },
        "default_on_expire": { "type": ["string", "null"] },
        "callback": { "$ref": "#/$defs/callback" }
      },
      "allOf": [
        { "if": { "properties": { "mode": { "const": "select" } } }, "then": { "required": ["options"] } },
        { "if": { "properties": { "mode": { "const": "input" } } }, "then": { "required": ["schema"] } }
      ]
    },
    "action": {
      "type": "object",
      "required": ["instructions"],
      "properties": {
        "instructions": { "type": "string" },
        "checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text"],
            "properties": { "text": { "type": "string" }, "done": { "type": "boolean", "default": false } }
          }
        },
        "verification": { "type": "string" },
        "callback": { "$ref": "#/$defs/callback" }
      }
    },
    "callback": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["push", "pull"] },
        "url": { "type": "string", "format": "uri" },
        "auth": {
          "type": "object",
          "required": ["scheme"],
          "properties": {
            "scheme": { "enum": ["hmac", "bearer", "apikey"] },
            "secret_ref": { "type": "string" },
            "token_ref": { "type": "string" }
          }
        }
      },
      "if": { "properties": { "mode": { "const": "push" } } },
      "then": { "required": ["url"] }
    }
  }
}
