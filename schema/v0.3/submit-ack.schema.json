{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2hprotocol.org/schema/v0.3/submit-ack.schema.json",
  "title": "A2H Submit Ack (v0.3)",
  "description": "Body of the 202 Accepted returned by POST /v1/messages.",
  "type": "object",
  "required": ["id", "status", "poll_url"],
  "properties": {
    "id": { "type": "string", "minLength": 1, "description": "Hub-assigned canonical message id." },
    "status": { "enum": ["open", "delivered"], "description": "`open` for ask/task; `delivered` for notify." },
    "poll_url": { "type": "string", "format": "uri" },
    "review_url": { "type": "string", "format": "uri", "description": "Human-facing deep link." }
  },
  "additionalProperties": false
}
