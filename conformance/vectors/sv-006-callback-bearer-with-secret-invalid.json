{
  "id": "sv-006-callback-bearer-with-secret-invalid",
  "class": "schema-validation",
  "description": "callback.auth scheme=bearer carrying secret_ref (the wrong field) is rejected; bearer requires token_ref only.",
  "ref": "spec §8.3, §9.2",
  "target": "message.schema.json",
  "expect": "invalid",
  "input": {
    "a2h_version": "0.3",
    "type": "ask",
    "created_at": "2026-06-04T15:00:00Z",
    "agent": { "id": "deploybot/dev-team", "run_id": "r1", "runtime": "github-actions" },
    "title": "Bad bearer callback",
    "idempotency_key": "k2",
    "request": {
      "mode": "confirm",
      "callback": { "mode": "push", "url": "https://deploybot.example/a2h/resume", "auth": { "scheme": "bearer", "secret_ref": "env:X" } }
    }
  }
}
