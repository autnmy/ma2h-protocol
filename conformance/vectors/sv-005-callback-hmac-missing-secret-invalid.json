  "class": "schema-validation",
  "description": "callback.auth scheme=hmac without secret_ref is rejected (per-scheme conditional).",
  "ref": "spec §8.3, §9.2",
  "target": "message.schema.json",
  "expect": "invalid",
  "input": {
