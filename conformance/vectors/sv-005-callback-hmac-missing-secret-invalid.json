    "title": "Bad hmac callback",
    "idempotency_key": "k1",
    "request": {
      "mode": "confirm",
      "callback": { "mode": "push", "url": "https://deploybot.example/a2h/resume", "auth": { "scheme": "hmac" } }
    }
  }
